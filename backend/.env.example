# TinyFish Web Agent API Configuration
TINYFISH_API_KEY=your_api_key_here

# Backend Port
PORT=3001

# ── Partner Stack ──────────────────────────────────────────────────────────────
# AgentOps — Agent session observability (https://agentops.ai)
AGENTOPS_API_KEY=your_agentops_api_key_here

# Axiom — Structured logging (https://axiom.co)
AXIOM_API_KEY=your_axiom_api_key_here
AXIOM_DATASET=revrecover-logs

# ElevenLabs — AI voice TTS proxy (https://elevenlabs.io)
# Key is kept here on the backend only — never exposed to the browser.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# MongoDB Atlas — Managed Database (https://www.mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/revrecover?retryWrites=true&w=majority

